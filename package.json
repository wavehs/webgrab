{
  "name": "webgrab",
  "version": "1.0.0",
  "description": "CLI tool to grab web pages as PDF, HTML, MHTML, Screenshot, Markdown, or Text",
  "main": "src/cli.js",
  "type": "module",
  "bin": {
    "webgrab": "./bin/webgrab.js"
  },
  "scripts": {
    "start": "node bin/webgrab.js",
    "test": "vitest run",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration",
    "test:e2e": "vitest run tests/e2e",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest watch"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^15.0.0",
    "html-to-text": "^10.0.0",
    "playwright": "^1.60.0",
    "turndown": "^7.2.4",
    "turndown-plugin-gfm": "^1.0.2"
  },
  "devDependencies": {
    "@vitest/coverage-v8": "^4.1.8",
    "vitest": "^4.1.8"
  }
}
